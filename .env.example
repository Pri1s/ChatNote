# Copy this file to .env and fill in real values. .env is gitignored and
# should never be committed. See the "MVP Quickstart" section in README.md.

# Required for `chatnote extract` / `chatnote run` without --claims-json.
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Required unless --model is passed on the CLI. Any OpenRouter model slug,
# e.g. anthropic/claude-sonnet-5, openai/gpt-5, google/gemini-3-pro.
CHATNOTE_MODEL=

# Optional. Defaults to https://openrouter.ai/api/v1. Override to point at
# any other OpenAI-compatible endpoint (local Ollama, vLLM, etc.).
CHATNOTE_LLM_BASE_URL=
